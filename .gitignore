# Enlace técnico recreable hacia estado externo al checkout
.riel-instance.json

# Raíces heredadas: siguen ignoradas para no publicar datos durante una
# migración, pero `riel doctor` las considera un error y exige retirarlas.
org/
engagements/
clients/
projects/
casos/
bus/
.riel/
bandeja/

# Agentes locales heredados: no pertenecen al checkout distribuible
.codex/agents/local-*.toml

# Secretos y credenciales
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials*.json
secrets*.json

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/
.venv/
venv/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Salidas locales
build/
dist/
*.log
*.tmp
