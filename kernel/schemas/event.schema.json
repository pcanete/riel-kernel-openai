{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riel.local/schemas/event.schema.json",
  "title": "Riel Event",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "type",
    "status",
    "sender",
    "recipient",
    "scope",
    "created_at",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "minLength": 3
    },
    "type": {
      "enum": [
        "context",
        "task",
        "decision",
        "handoff",
        "block",
        "approval",
        "close",
        "audit"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "sender": {
      "type": "string",
      "minLength": 1
    },
    "recipient": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    },
    "correlation_id": {
      "type": "string"
    },
    "closes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "close"
          }
        }
      },
      "then": {
        "required": [
          "closes"
        ]
      }
    }
  ],
  "additionalProperties": false
}
