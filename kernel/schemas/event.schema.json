{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pcanete/riel-kernel-openai/kernel/schemas/event.schema.json",
  "title": "Riel shared event",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "organization_ref", "actor_ref", "created_at", "summary", "record_ref"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "enum": ["task", "decision", "handoff", "blocker", "approval", "context"] },
    "organization_ref": { "type": "string", "minLength": 1 },
    "engagement_ref": { "type": ["string", "null"] },
    "actor_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "minLength": 1 },
    "record_ref": { "type": "string", "minLength": 1 },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    }
  }
}
