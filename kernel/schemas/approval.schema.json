{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pcanete/riel-kernel-openai/kernel/schemas/approval.schema.json",
  "title": "Riel shared business decision",
  "description": "Logical shape for a decision stored by a shared-system adapter. It is not a technical permission token.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "organization_ref", "engagement_ref", "requested_by_ref",
    "action", "scope", "risk", "reversible", "decision",
    "requested_at", "record_ref"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "organization_ref": { "type": "string", "minLength": 1 },
    "engagement_ref": { "type": ["string", "null"] },
    "requested_by_ref": { "type": "string", "minLength": 1 },
    "decided_by_ref": { "type": ["string", "null"] },
    "action": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "risk": { "enum": ["low", "medium", "high", "critical"] },
    "reversible": { "type": "boolean" },
    "decision": { "enum": ["pending", "approved", "denied", "expired"] },
    "requested_at": { "type": "string", "format": "date-time" },
    "decided_at": { "type": ["string", "null"], "format": "date-time" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "record_ref": { "type": "string", "minLength": 1 },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    }
  }
}
