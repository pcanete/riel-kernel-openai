{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/session_start.py\"",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); py -3 `\"$r\\.codex\\hooks\\session_start.py`\"\"",
            "timeout": 15,
            "statusMessage": "Cargando estado de Riel"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/guard.py\"",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); py -3 `\"$r\\.codex\\hooks\\guard.py`\"\"",
            "timeout": 20,
            "statusMessage": "Verificando permisos y aprobación"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/audit.py\"",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); py -3 `\"$r\\.codex\\hooks\\audit.py`\"\"",
            "timeout": 15,
            "statusMessage": "Registrando trazabilidad mínima"
          }
        ]
      }
    ]
  }
}
